# Layout dichiarativo delle schermate di DiviConto (KivyMD 1.2.0).
# Le scritte passano da app.tr(...) per la localizzazione (vedi diviconto/i18n.py).

<AuthScreen>:
    MDBoxLayout:
        orientation: "vertical"
        MDTopAppBar:
            title: app.tr("DiviConto — Accedi")
        MDFloatLayout:
            MDBoxLayout:
                orientation: "vertical"
                spacing: "16dp"
                padding: "24dp"
                size_hint: None, None
                width: min(root.width - dp(48), dp(360))
                height: self.minimum_height
                pos_hint: {"center_x": .5, "top": .92}
                adaptive_height: True
                MDLabel:
                    text: app.tr("Accedi per sincronizzare le spese del tuo viaggio")
                    halign: "center"
                    adaptive_height: True
                    size_hint_y: None
                    text_size: self.width, None
                    height: self.texture_size[1]
                MDBoxLayout:
                    orientation: "vertical"
                    adaptive_height: True
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: "2dp"
                    MDLabel:
                        text: app.tr("Email")
                        bold: True
                        theme_text_color: "Primary"
                        adaptive_height: True
                        size_hint_y: None
                        height: self.texture_size[1]
                    FormTextField:
                        id: email
                        hint_text: ""
                        mode: "rectangle"
                        input_type: "mail"
                MDBoxLayout:
                    orientation: "vertical"
                    adaptive_height: True
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: "2dp"
                    MDLabel:
                        text: app.tr("Password")
                        bold: True
                        theme_text_color: "Primary"
                        adaptive_height: True
                        size_hint_y: None
                        height: self.texture_size[1]
                    FormTextField:
                        id: password
                        hint_text: ""
                        mode: "rectangle"
                        password: True
                MDRaisedButton:
                    text: app.tr("Accedi")
                    pos_hint: {"center_x": .5}
                    on_release: root.do_login()
                MDFlatButton:
                    text: app.tr("Registrati")
                    pos_hint: {"center_x": .5}
                    on_release: root.do_signup()
                MDFlatButton:
                    text: app.tr("Continua senza account (solo su questo telefono)")
                    pos_hint: {"center_x": .5}
                    on_release: root.use_offline()
                MDLabel:
                    id: status
                    text: ""
                    halign: "center"
                    adaptive_height: True
                    theme_text_color: "Error"


<TripsScreen>:
    MDBoxLayout:
        orientation: "vertical"
        MDTopAppBar:
            title: app.tr("DiviConto — Viaggi")
            right_action_items:
                [["sync", lambda x: root.do_sync(), app.tr("Sincronizza")], \
                ["account-multiple-plus", lambda x: root.open_join_dialog(), app.tr("Unisciti a un viaggio")], \
                ["cog", lambda x: root.open_settings(), app.tr("Impostazioni")]]
        MDBoxLayout:
            size_hint_y: None
            height: "52dp"
            padding: "12dp", "4dp"
            spacing: "8dp"
            md_bg_color: app.theme_cls.primary_light
            MDLabel:
                id: account_label
                text: ""
                valign: "center"
                shorten: True
                shorten_from: "right"
            MDRaisedButton:
                id: account_btn
                text: app.tr("Esci")
                pos_hint: {"center_y": .5}
                on_release: root.account_action()
        MDFloatLayout:
            ScrollView:
                MDList:
                    id: trip_list
            MDFloatingActionButton:
                icon: "plus"
                type: "standard"
                pos_hint: {"center_x": .9, "center_y": .1}
                on_release: root.open_new_trip_dialog()


<TripDetailScreen>:
    MDBoxLayout:
        orientation: "vertical"
        MDTopAppBar:
            id: topbar
            title: app.tr("Viaggio")
            left_action_items: [["arrow-left", lambda x: root.go_back()]]
            right_action_items:
                [["sync", lambda x: root.do_sync(), app.tr("Sincronizza")], \
                ["share-variant", lambda x: root.show_share_code(), app.tr("Condividi")], \
                ["dots-vertical", lambda x: root.open_trip_menu(), app.tr("Gestisci viaggio")]]
        MDBottomNavigation:
            id: bottom_nav

            MDBottomNavigationItem:
                name: "expenses"
                text: app.tr("Spese")
                icon: "receipt"
                MDFloatLayout:
                    ScrollView:
                        MDList:
                            id: expense_list
                    MDFloatingActionButton:
                        icon: "plus"
                        pos_hint: {"center_x": .9, "center_y": .1}
                        on_release: root.open_expense_form()

            MDBottomNavigationItem:
                name: "people"
                text: app.tr("Persone")
                icon: "account-group"
                MDBoxLayout:
                    orientation: "vertical"
                    MDBoxLayout:
                        size_hint_y: None
                        height: "72dp"
                        padding: "8dp"
                        spacing: "8dp"
                        FormTextField:
                            id: new_person
                            hint_text: app.tr("Nome partecipante")
                            mode: "rectangle"
                        MDRaisedButton:
                            text: app.tr("Aggiungi")
                            size_hint_x: None
                            width: "120dp"
                            on_release: root.add_person()
                    ScrollView:
                        MDList:
                            id: people_list

            MDBottomNavigationItem:
                name: "balance"
                text: app.tr("Bilancio")
                icon: "scale-balance"
                ScrollView:
                    MDBoxLayout:
                        id: balance_box
                        orientation: "vertical"
                        adaptive_height: True
                        size_hint_y: None
                        padding: "12dp"
                        spacing: "2dp"


<ExpenseFormScreen>:
    MDBoxLayout:
        orientation: "vertical"
        MDTopAppBar:
            title: app.tr("Nuova spesa")
            left_action_items: [["arrow-left", lambda x: root.go_back()]]
        ScrollView:
            MDBoxLayout:
                id: form_box
                orientation: "vertical"
                adaptive_height: True
                size_hint_y: None
                padding: "16dp"
                spacing: "12dp"
        MDRaisedButton:
            text: app.tr("Salva spesa")
            pos_hint: {"center_x": .5}
            size_hint_y: None
            height: "48dp"
            on_release: root.save()


<SettingsScreen>:
    MDBoxLayout:
        orientation: "vertical"
        MDTopAppBar:
            title: app.tr("Impostazioni")
            left_action_items: [["arrow-left", lambda x: root.go_back()]]
        MDBoxLayout:
            orientation: "vertical"
            padding: "16dp"
            spacing: "12dp"
            MDLabel:
                text: app.tr("Lingua")
                bold: True
                adaptive_height: True
                size_hint_y: None
                height: self.texture_size[1]
            MDRaisedButton:
                text: app.tr("Italiano")
                pos_hint: {"center_x": .5}
                on_release: root.set_language("it")
            MDRaisedButton:
                text: app.tr("English")
                pos_hint: {"center_x": .5}
                on_release: root.set_language("en")
            MDBoxLayout:
