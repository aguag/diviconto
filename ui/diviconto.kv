# Layout dichiarativo delle schermate di DiviConto (KivyMD 1.2.0).

<AuthScreen>:
    MDBoxLayout:
        orientation: "vertical"
        MDTopAppBar:
            title: "DiviConto — Accedi"
        MDFloatLayout:
            MDBoxLayout:
                orientation: "vertical"
                spacing: "16dp"
                padding: "24dp"
                size_hint: None, None
                width: min(root.width - dp(48), dp(360))
                height: self.minimum_height
                pos_hint: {"center_x": .5, "center_y": .55}
                adaptive_height: True
                MDLabel:
                    text: "Accedi per sincronizzare le spese tra telefoni"
                    halign: "center"
                    adaptive_height: True
                MDTextField:
                    id: email
                    hint_text: "Email"
                MDTextField:
                    id: password
                    hint_text: "Password"
                    password: True
                MDRaisedButton:
                    text: "Accedi"
                    pos_hint: {"center_x": .5}
                    on_release: root.do_login()
                MDFlatButton:
                    text: "Registrati"
                    pos_hint: {"center_x": .5}
                    on_release: root.do_signup()
                MDFlatButton:
                    text: "Usa offline (senza account)"
                    pos_hint: {"center_x": .5}
                    on_release: root.use_offline()


<TripsScreen>:
    MDBoxLayout:
        orientation: "vertical"
        MDTopAppBar:
            title: "DiviConto — Viaggi"
            right_action_items:
                [["sync", lambda x: root.do_sync(), "Sincronizza"], \
                ["account-multiple-plus", lambda x: root.open_join_dialog(), "Unisciti a un viaggio"], \
                ["logout", lambda x: root.do_logout(), "Disconnetti"]]
        MDFloatLayout:
            ScrollView:
                MDList:
                    id: trip_list
            MDFloatingActionButton:
                icon: "plus"
                type: "standard"
                pos_hint: {"center_x": .9, "center_y": .1}
                on_release: root.open_new_trip_dialog()


<TripDetailScreen>:
    MDBoxLayout:
        orientation: "vertical"
        MDTopAppBar:
            id: topbar
            title: "Viaggio"
            left_action_items: [["arrow-left", lambda x: root.go_back()]]
            right_action_items:
                [["sync", lambda x: root.do_sync(), "Sincronizza"], \
                ["share-variant", lambda x: root.show_share_code(), "Condividi"]]
        MDBottomNavigation:
            id: bottom_nav

            MDBottomNavigationItem:
                name: "expenses"
                text: "Spese"
                icon: "receipt"
                MDFloatLayout:
                    ScrollView:
                        MDList:
                            id: expense_list
                    MDFloatingActionButton:
                        icon: "plus"
                        pos_hint: {"center_x": .9, "center_y": .1}
                        on_release: root.open_expense_form()

            MDBottomNavigationItem:
                name: "people"
                text: "Persone"
                icon: "account-group"
                MDBoxLayout:
                    orientation: "vertical"
                    MDBoxLayout:
                        size_hint_y: None
                        height: "72dp"
                        padding: "8dp"
                        spacing: "8dp"
                        MDTextField:
                            id: new_person
                            hint_text: "Nome partecipante"
                        MDRaisedButton:
                            text: "Aggiungi"
                            size_hint_x: None
                            width: "120dp"
                            on_release: root.add_person()
                    ScrollView:
                        MDList:
                            id: people_list

            MDBottomNavigationItem:
                name: "balance"
                text: "Bilancio"
                icon: "scale-balance"
                ScrollView:
                    MDBoxLayout:
                        id: balance_box
                        orientation: "vertical"
                        adaptive_height: True
                        size_hint_y: None
                        padding: "12dp"
                        spacing: "2dp"


<ExpenseFormScreen>:
    MDBoxLayout:
        orientation: "vertical"
        MDTopAppBar:
            title: "Nuova spesa"
            left_action_items: [["arrow-left", lambda x: root.go_back()]]
        ScrollView:
            MDBoxLayout:
                id: form_box
                orientation: "vertical"
                adaptive_height: True
                size_hint_y: None
                padding: "16dp"
                spacing: "12dp"
        MDRaisedButton:
            text: "Salva spesa"
            pos_hint: {"center_x": .5}
            size_hint_y: None
            height: "48dp"
            on_release: root.save()
