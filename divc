#!/usr/bin/env python3
"""Wrapper eseguibile: lancia la CLI di DiviConto senza installazione.

Uso: ./divc -h
Funziona se eseguito dalla cartella del progetto (Linux/Fedora e Termux).
"""

import os
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

from diviconto.cli import main  # noqa: E402

if __name__ == "__main__":
    raise SystemExit(main())
